# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Deepgram: https://console.deepgram.com/project/_/keys
DEEPGRAM_API_KEY=

# Cartesia: https://play.cartesia.ai/keys
CARTESIA_API_KEY=

# Inworld: https://studio.inworld.ai/  then Settings > API Keys
INWORLD_API_KEY=

# LMNT: https://app.lmnt.com/account
LMNT_API_KEY=

# Azure AI Speech: https://portal.azure.com/  create Speech resource, then Keys and Endpoint
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Google Cloud Text-to-Speech: Place service account JSON at ~/.config/google-cloud/google-tts-bobby.json
# No env var needed — the code reads the JSON directly

# Amazon Polly IAM user/access key. Prefer a restricted IAM policy for Polly only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
